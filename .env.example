# Environment template for the Autodesk BIM Workflow Reference Implementation.
#
# Copy this file to `.env` and fill in local values. `.env` is git-ignored and
# must never be committed.
#
# This file MUST contain safe placeholders only. Do not add tokens, client IDs,
# client secrets, callback URLs, Autodesk project/hub/folder identifiers, or
# machine-specific absolute paths.

# Local checkout path of the APS/Forma MCP component repository
# (CognitiveStack/autodesk-aps-forma-mcp).
FORMA_MCP_REPO=

# Local checkout path of the Revit MCP component repository
# (CognitiveStack/revit-mcp-triviron).
REVIT_MCP_REPO=
